# Copy to .env and adjust. All vars are prefixed DBAGENT_.

# Semantic layer (the agent's map). Defaults to repo-root semantic_layer.yaml.
# DBAGENT_SEMANTIC_LAYER_PATH=semantic_layer.yaml

# Read replica — MUST be a restricted read-only role on the replica.
DBAGENT_REPLICA_DSN=postgresql://readonly:secret@replica.internal:5432/tumordb
DBAGENT_STATEMENT_TIMEOUT_MS=15000

# Query guard rails
DBAGENT_DEFAULT_LIMIT=1000
DBAGENT_MAX_LIMIT=10000
DBAGENT_MAX_SQL_RETRIES=3

# Observability — append one JSONL record per run. Unset = disabled.
# DBAGENT_OBSERVABILITY_LOG_PATH=logs/runs.jsonl

# LiteLLM gateway + aliases (SQL generation routes to qwen-code)
DBAGENT_LITELLM_BASE_URL=http://litellm.internal:4000
DBAGENT_LITELLM_API_KEY=sk-xxxx
DBAGENT_MODEL_ROUTE=qwen-main
DBAGENT_MODEL_FAST=qwen-fast
DBAGENT_MODEL_SQL=qwen-code
